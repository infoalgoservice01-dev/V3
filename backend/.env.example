# ELD Integration Backend — Environment Variables
# Copy this file to .env and fill in real values.

# ─── Server ────────────────────────────────────────────────
PORT=5000

# Cron schedule (default: every hour at minute 0)
# Use '* * * * *' for every minute during testing
CRON_SCHEDULE=0 * * * *

# ─── Leader ELD API (drivehos.app) ─────────────────────────
ELD_API_BASE_URL=https://api.drivehos.app/api/v1
ELD_API_USERNAME=rayyan@algogroup.us
ELD_API_PASSWORD=mL9@Q2v#T4xR

# Optional: If you know your tenant_id (auto-detected from login if blank)
ELD_TENANT_ID=

# ─── Firebase Service Account ───────────────────────────────
# Download from: Firebase Console → Project Settings → Service accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT_PATH=./service_account_key.json

# ─── Email (Nodemailer SMTP) ────────────────────────────────
# Option A: Gmail with App Password (recommended)
#   1. Enable 2FA on your Google account
#   2. Go to Google Account → Security → App Passwords → Generate
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=WestA@algogroup.us
SMTP_PASS=dtkq fhya dvyu gmcx
SMTP_FROM="Leader A1 Fleet Monitor <your_gmail@gmail.com>"

# Leave SMTP_HOST blank → runs in email simulation mode (no real emails sent)
# Firebase Admin (no JSON file needed — use these directly)
FIREBASE_PROJECT_ID=base-notify
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# Your Firebase Auth UID (the admin who logged into the app)
FIREBASE_USER_ID=your-firebase-user-uid
